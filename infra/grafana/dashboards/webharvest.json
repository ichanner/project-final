{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Status — at a glance (5-second test: is anything red?)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "scraper",
      "description": "FastAPI service for source CRUD, manual runs, /metrics. up=1 means Prometheus successfully scraped its /metrics in the last interval.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"scraper\"}", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "worker",
      "description": "APScheduler container that fires per-source cron jobs. up=0 here means scheduled polls are silently not happening — the API is still serving but background scraping has stopped.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"worker\"}", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "extracto",
      "description": "Node service that wraps OpenRouter for anchoring LLM calls. Only invoked on first-run or operator-triggered re-anchor — should be UP but mostly idle.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"extracto\"}", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "prometheus",
      "description": "Self-scrape — confirms metric ingestion itself is alive.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"prometheus\"}", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active alerts",
      "description": "Count of alert rules currently firing. Green=0, yellow=1-3, red=4+. Drill into the diagnostic row at the bottom for the full list.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 4 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background", "textMode": "value" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active sources",
      "description": "Sources that have polled at least once. A drop here without intent means the worker dropped jobs.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(count by(source_id) (webharvest_poll_total)) or vector(0)", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value", "textMode": "value" }
    },

    {
      "id": 200,
      "type": "row",
      "title": "Rate — is the system doing work?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Polls / min (all sources)",
      "description": "Total poll throughput. Should match the sum of cron cadences across active sources. A sudden drop here is the same signal as PollSilent at the global level.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(webharvest_poll_total[5m]) * 60) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Polls / min per source",
      "description": "Per-source poll cadence over time. Each source's line should be a steady plateau matching its cron interval. Gaps mean the worker stopped firing that job.",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(source_id) (rate(webharvest_poll_total[5m]) * 60)", "legendFormat": "src {{source_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },

    {
      "id": 300,
      "type": "row",
      "title": "Errors — what's failing?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Fetch failures by error_class",
      "description": "Operational failure taxonomy. Each error_class has a different remediation: timeout / dns → check upstream; http_4xx → check auth/anti-bot; anti_bot → rotate UA or pause; http_5xx → upstream incident.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(error_class) (rate(webharvest_fetch_errors_total[5m]) * 60)", "legendFormat": "{{error_class}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Consecutive failures per source",
      "description": "Number of consecutive failed fetches per source. Resets to 0 on next success. ≥5 fires the ConsecutiveFetchFailures alert. The source-level operator-attention signal.",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "webharvest_fetch_consecutive_failures > 0", "legendFormat": "src {{source_id}}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0, "min": 0, "max": 10,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "lcd", "showUnfilled": true }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Cron skips / hr",
      "description": "APScheduler misfires (clock drift) or max_instances drops (previous run still in flight). Non-zero values mean the worker is overloaded or stuck. Splits the failure across reasons.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(webharvest_polls_skipped_total[15m]) * 3600) or vector(0)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "/h", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },

    {
      "id": 400,
      "type": "row",
      "title": "Duration — is anything slow?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Poll duration p50 / p95 per source",
      "description": "End-to-end pipeline time per source. p95 spikes typically mean an LLM anchoring run, slow upstream, or large page. Steady-state polls should be sub-second.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le, source_id) (rate(webharvest_poll_duration_seconds_bucket[5m])))", "legendFormat": "src {{source_id}} p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by(le, source_id) (rate(webharvest_poll_duration_seconds_bucket[5m])))", "legendFormat": "src {{source_id}} p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Fast-path latency p95 (BS4 only, no LLM)",
      "description": "Pure BeautifulSoup extraction time on cached anchors. Should stay flat in the 50-100ms range. Climbing values mean the page is bigger or selectors are slow.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, source_id) (rate(webharvest_fast_path_duration_seconds_bucket[5m])))", "legendFormat": "src {{source_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 500,
      "type": "row",
      "title": "Activity proof — is the system producing useful output?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Field changes / min (top 10)",
      "description": "Volatile-field drift detected by the diff loop. This is the system's product — it ticks every poll on sources with changing prices/counts/state. Flat line means the page is genuinely stable, not that the pipeline is broken.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum by(source_id, field) (rate(webharvest_field_changes_total[5m]) * 60))", "legendFormat": "src{{source_id}} · {{field}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Entity transitions (new / updated / stale)",
      "description": "Per-poll entity churn. New = first time seen this identity. Updated = volatile field changed. Stale = identity disappeared from the source. Sustained 'stale' bursts trigger StaleEntitySpike.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(change) (rate(webharvest_scraper_run_entities_total[5m]) * 60)", "legendFormat": "{{change}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Entity count per source (anchor extraction)",
      "description": "Last fast-path entity count per source. Sudden drops mean the cached anchor recipe is degrading — the AnchorBreakage alert watches the same metric on a 1h moving average.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "webharvest_anchor_extraction_count", "legendFormat": "src {{source_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Polls by path (fast-path vs LLM anchor)",
      "description": "Operational composition of the polling workload. Steady state should be 100% dom_fast_path. Any llm_anchor activity means new sources are bootstrapping or anchors got invalidated.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(path) (rate(webharvest_poll_total[5m]) * 60)", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },

    {
      "id": 600,
      "type": "row",
      "title": "Diagnostic log — drill here when something is wrong",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": true,
      "panels": [
        {
          "id": 18,
          "type": "alertlist",
          "title": "Currently firing alerts",
          "description": "Live view of every Prometheus alert in firing state. Each entry includes summary + remediation in annotations.",
          "gridPos": { "h": 9, "w": 12, "x": 0, "y": 50 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "options": {
            "showOptions": "current",
            "maxItems": 20,
            "sortOrder": 3,
            "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": false, "error": true }
          }
        },
        {
          "id": 19,
          "type": "table",
          "title": "Recent failures (postgres)",
          "description": "Postgres-backed tail of runs with non-null error. Higher fidelity than Prometheus for forensic detail — captures the actual exception text from runner.py.",
          "gridPos": { "h": 9, "w": 12, "x": 12, "y": 50 },
          "datasource": { "type": "postgres", "uid": "postgres" },
          "targets": [
            {
              "rawSql": "SELECT r.started_at AS \"time\", r.source_id AS \"src\", r.backend AS \"path/model\", left(coalesce(r.error, ''), 120) AS \"error\" FROM runs r WHERE r.error IS NOT NULL ORDER BY r.started_at DESC LIMIT 30",
              "format": "table",
              "refId": "A"
            }
          ]
        },
        {
          "id": 20,
          "type": "table",
          "title": "Recent runs (postgres)",
          "description": "Per-poll event log: which source, which path (fast-path or anchoring model), entity counts and cost. The operator-readable equivalent of what the metrics aggregate.",
          "gridPos": { "h": 9, "w": 24, "x": 0, "y": 59 },
          "datasource": { "type": "postgres", "uid": "postgres" },
          "targets": [
            {
              "rawSql": "SELECT r.started_at AS \"time\", r.source_id AS \"src\", r.backend AS \"path/model\", r.entity_count AS \"entities\", r.new_count AS \"new\", r.updated_count AS \"updated\", r.stale_count AS \"stale\", r.cost_usd AS \"cost\", left(coalesce(r.error, ''), 80) AS \"error\" FROM runs r ORDER BY r.started_at DESC LIMIT 50",
              "format": "table",
              "refId": "A"
            }
          ]
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["webharvest", "devops", "operational"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WebHarvest Operations",
  "uid": "webharvest",
  "version": 5,
  "weekStart": ""
}
