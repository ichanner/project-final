{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Fetches/min by outcome",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by(outcome) (rate(webharvest_scraper_fetch_total[5m]) * 60)", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Entities by change type",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        { "expr": "sum by(change) (rate(webharvest_scraper_run_entities_total[5m]))", "legendFormat": "{{change}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Confidence by backend (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by(le, backend) (rate(webharvest_scraper_run_confidence_bucket[5m])))", "legendFormat": "p50 {{backend}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by(le, backend) (rate(webharvest_scraper_run_confidence_bucket[5m])))", "legendFormat": "p95 {{backend}}", "refId": "B" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cost by model (USD/hr)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by(model) (rate(extracto_cost_usd_total[1h]) * 3600)", "legendFormat": "{{model}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Fetch p95 by source",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, source_id) (rate(webharvest_scraper_fetch_duration_seconds_bucket[5m])))", "legendFormat": "src {{source_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Escalation rate to cloud (per model)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "sum by(model) (rate(webharvest_scraper_escalations_total[5m]))", "legendFormat": "{{model}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tokens/sec by model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "sum by(model, kind) (rate(extracto_tokens_total[5m]))", "legendFormat": "{{model}} {{kind}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Extraction latency p95 by model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, model) (rate(extracto_extract_duration_seconds_bucket[5m])))", "legendFormat": "{{model}} p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Inter-model agreement (Jaccard, vs primary)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "targets": [
        { "expr": "webharvest_agreement_jaccard", "legendFormat": "src{{source_id}}: {{primary}} vs {{challenger}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "description": "1.0 = perfect overlap of identity_keys with the primary model. 0 = no agreement. Pick a primary you trust and watch challengers drift."
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Total spend (this dashboard window)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 30 },
      "targets": [
        { "expr": "sum(extracto_cost_usd_total)", "legendFormat": "total $", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Spend by model (USD)",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 30 },
      "targets": [
        { "expr": "sum by(model) (extracto_cost_usd_total)", "legendFormat": "{{model}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    }
  ],
  "refresh": "10s",
