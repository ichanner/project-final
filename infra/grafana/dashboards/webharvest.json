{
  "annotations": {
    "list": [
      {
        "name": "Field changes",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "iconColor": "rgba(245, 176, 66, 0.9)",
        "expr": "increase(webharvest_field_changes_total[1m]) > 0",
        "step": "30s",
        "tagKeys": "source_id,field",
        "titleFormat": "{{field}} changed on src {{source_id}}",
        "useValueForTime": false
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    { "id": 100, "type": "row", "title": "Diff & drift", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false, "panels": [] },

    {
      "id": 1,
      "type": "stat",
      "title": "Field changes (last 1h)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(webharvest_field_changes_total[1h]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        {"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "orange", "value": 50}
      ]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Updated entities (last 1h)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(webharvest_scraper_run_entities_total{change=\"updated\"}[1h]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active sources (have run in last 10m)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(count by(source_id) (rate(webharvest_scraper_fetch_total[10m]) > 0))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total spend (window)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(extracto_cost_usd_total)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Field change rate (per minute)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Each line is one (source, field). Spikes mean that field is currently churning.",
      "targets": [
        { "expr": "sum by(source_id, field) (rate(webharvest_field_changes_total[5m]) * 60)", "legendFormat": "src{{source_id}} · {{field}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "/min" } }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Top changing fields (last 1h)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Which fields are responsible for the most drift recently. Useful for sizing where to focus inspection.",
      "targets": [
        { "expr": "topk(15, sum by(source_id, field) (increase(webharvest_field_changes_total[1h])))", "legendFormat": "src{{source_id}} · {{field}}", "refId": "A" }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },

    {
      "id": 12,
      "type": "table",
      "title": "Most volatile entities (last 1h, from Postgres)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "description": "Per-entity update count from the entity_changes log. Click headers to sort. Operational read: which specific entities are flapping?",
      "targets": [
        {
          "rawSql": "SELECT e.identity AS \"entity\", c.source_id AS \"source\", count(*) AS \"changes_1h\", count(DISTINCT c.field) AS \"fields_touched\", max(c.changed_at) AS \"last_change\" FROM entity_changes c JOIN entities e ON e.id = c.entity_id WHERE c.changed_at > now() - interval '1 hour' GROUP BY e.identity, c.source_id ORDER BY changes_1h DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "changes_1h" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              {"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "orange", "value": 10}, {"color": "red", "value": 30}
            ]}}
          ]}
        ]
      }
    },

    {
      "id": 14,
      "type": "stat",
      "title": "Fast-path hit rate (last 10m)",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Per-source cached-anchor SLI. Healthy = 95%+ hit rate (most polls free, LLM only invoked when page changed). Drops = pay credits + alert fires.",
      "targets": [
        {
          "expr": "sum by(source_id) (rate(webharvest_fast_path_total{outcome=\"hit\"}[10m])) / sum by(source_id) (rate(webharvest_fast_path_total[10m]))",
          "legendFormat": "src {{source_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1, "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.5},
            {"color": "yellow", "value": 0.7},
            {"color": "green", "value": 0.95}
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Fast-path latency p95 (BeautifulSoup, no LLM)",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, source_id) (rate(webharvest_fast_path_duration_seconds_bucket[5m])))", "legendFormat": "src {{source_id}} p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    { "id": 200, "type": "row", "title": "Model bake-off (only fires when anchors miss)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }, "collapsed": false, "panels": [] },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Cost by model (USD/hr)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(model) (rate(extracto_cost_usd_total[1h]) * 3600)", "legendFormat": "{{model}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Extraction latency p95 by model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, model) (rate(extracto_extract_duration_seconds_bucket[5m])))", "legendFormat": "{{model}} p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Set-level agreement (Jaccard, vs primary)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "webharvest_agreement_jaccard", "legendFormat": "src{{source_id}}: {{challenger}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Per-field agreement vs primary",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "webharvest_field_agreement", "legendFormat": "{{challenger}} · {{field}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 24,
      "type": "table",
      "title": "Field agreement matrix (latest)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "webharvest_field_agreement", "format": "table", "instant": true, "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "displayMode": "color-background" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.7},
            {"color": "yellow", "value": 0.9},
            {"color": "green", "value": 0.97}
          ]}
        }
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "primary": true }, "renameByName": { "challenger": "Challenger", "field": "Field", "source_id": "Source", "Value": "Agreement" } } }
      ]
    },

    { "id": 300, "type": "row", "title": "Source health & runs", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }, "collapsed": false, "panels": [] },

    {
      "id": 30,
      "type": "stat",
      "title": "Fetches/min",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(outcome) (rate(webharvest_scraper_fetch_total[5m]) * 60)", "legendFormat": "{{outcome}}", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Entities by change type (rate / 5m)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(change) (rate(webharvest_scraper_run_entities_total[5m]) * 300)", "legendFormat": "{{change}}", "refId": "A" }
      ]
    },

    {
      "id": 32,
      "type": "table",
      "title": "Recent runs (Postgres)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 60 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "rawSql": "SELECT started_at, source_id, backend, is_primary, confidence, entity_count, updated_count, stale_count, cost_usd, agreement, error FROM runs ORDER BY started_at DESC LIMIT 50",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["webharvest"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "WebHarvest",
  "uid": "webharvest",
  "version": 3,
  "weekStart": ""
}
