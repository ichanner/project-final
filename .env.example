# Cloud LLM via OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Default model when a source doesn't specify one. Per-source models
# (e.g. "openai/gpt-4o", "meta-llama/llama-3.3-70b-instruct") override this.
EXTRACTO_DEFAULT_MODEL=anthropic/claude-sonnet-4

# Postgres
POSTGRES_USER=webharvest
POSTGRES_PASSWORD=webharvest
POSTGRES_DB=webharvest
DATABASE_URL=postgres://webharvest:webharvest@postgres:5432/webharvest

# Service URLs (in-network)
EXTRACTO_URL=http://extracto:8081
SCRAPER_URL=http://scraper:8080

# Refresh schedule
SCRAPER_REFRESH_CRON=0 */6 * * *

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
